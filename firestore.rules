rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net & Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common primitives/helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for students collection
    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    // Rules for sppBills collection
    match /sppBills/{billId} {
      allow read, write: if isSignedIn();
    }

    // Rules for savingsTransactions collection
    match /savingsTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Rules for realtimeNotifications collection
    match /realtimeNotifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    // Rules for attendanceLogs collection
    match /attendanceLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Rules for homeroomTeachers collection
    match /homeroomTeachers/{teacherId} {
      allow read, write: if isSignedIn();
    }

    // Rules for configs collection
    match /configs/{configId} {
      allow read, write: if isSignedIn();
    }
  }
}
